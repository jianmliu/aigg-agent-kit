{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2020", "DOM"],
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@aigg/npc-agent": ["packages/npc-agent/src/index.ts"],
      "@aigg/npc-agent/*": ["packages/npc-agent/src/*"],
      "@aigg/onchain": ["packages/onchain/src/index.ts"],
      "@aigg/onchain/*": ["packages/onchain/src/*"]
,
      "@aigg/gamekit": ["packages/gamekit/src/index.ts"],
      "@aigg/gamekit/*": ["packages/gamekit/src/*"],
      "@aigg/replay": ["packages/replay/src/index.ts"],
      "@aigg/replay/*": ["packages/replay/src/*"],
      "@aigg/cognition": ["packages/cognition/src/index.ts"],
      "@aigg/cognition/*": ["packages/cognition/src/*"]
    }
  },
  "include": ["packages"]
}
