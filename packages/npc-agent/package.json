  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "test:smoke": "tsx src/__tests__/cognition-loop.smoke.ts",
    "test:autodrive": "tsx src/__tests__/auto-drive-store.smoke.ts",
    "test:gcc": "tsx src/__tests__/gcc-ledger.smoke.ts",
    "test:metabolism": "tsx src/__tests__/metabolism.smoke.ts",
    "test:wounded": "tsx src/__tests__/metabolism-wounded.smoke.ts",
    "test:needs": "tsx src/__tests__/needs.smoke.ts",
    "test:tiering": "tsx src/__tests__/cross-server-tiering.smoke.ts",
    "test:asyncarchive": "tsx src/__tests__/tiered-async-archive.smoke.ts",
    "test:attest": "tsx src/__tests__/autoinf-attestation.smoke.ts",
    "test:autoinf": "tsx src/__tests__/autoinf-broker.smoke.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "viem": "^2.51.3",
    "zod": "^3.23.8",
    "@ai3-inference/core": "workspace:*",
    "@ai3-inference/verify": "workspace:*",
    "@ai3-inference/broker": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.8.4",
    "tsx": "^4.21.0"
  }
}
