    "test:dsn": "tsx src/__tests__/shared-world-dsn.smoke.ts",
    "test:memory": "tsx src/__tests__/shared-world-memory.smoke.ts",
    "test:platform": "tsx src/__tests__/aigg-platform-npcs.smoke.ts",
    "test:settlement": "tsx src/__tests__/settlement-wiring.smoke.ts",
    "test:stf": "tsx src/__tests__/world-stf.smoke.ts",
    "test:verifiable": "tsx src/__tests__/verifiable-execution.smoke.ts",
    "test:persona": "tsx src/__tests__/persona-resolver.smoke.ts",
    "test:tick": "tsx src/__tests__/shared-world-tick.smoke.ts",
    "test:needs": "tsx src/__tests__/needs-world.smoke.ts",
    "test:economy-split": "tsx src/__tests__/economy-split.smoke.ts",
    "test:overhear": "tsx src/__tests__/shared-world-overhear.smoke.ts",
    "test:language": "tsx src/__tests__/language.smoke.ts",
