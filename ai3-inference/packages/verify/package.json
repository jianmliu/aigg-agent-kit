{
  "name": "@ai3-inference/verify",
  "version": "0.0.1",
  "private": true,
  "description": "Isomorphic verification: response signatures, quote binding, DCAP seam, tier allowlist, fusion receipts (plan T5/T6)",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "files": [
    "src",
    "dist",
    "fixtures"
  ],
  "scripts": {
    "build": "tsc -p .",
    "test": "node --import tsx --test \"src/**/*.test.ts\""
  },
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./fixtures/*": "./fixtures/*",
    "./package.json": "./package.json"
  },
  "dependencies": {
    "viem": "^2.51.3",
    "@ai3-inference/core": "workspace:*"
  },
  "devDependencies": {
    "@phala/dcap-qvl-node": "^0.3.3",
    "@types/node": "^22.7.5",
    "tsx": "^4.19.2"
  }
}
