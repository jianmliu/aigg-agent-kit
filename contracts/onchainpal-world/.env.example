# Copy to .env (gitignored) and fill in. Used by `forge create` to deploy KvWorld
# and by the kvworld-live cross-server smoke. NEVER commit real values.

# Base Sepolia RPC (not secret)
RPC_URL=https://sepolia.base.org

# Funded Base Sepolia deployer key (testnet gas). Secret — .env is gitignored.
PRIVATE_KEY=0x...

# Filled in AFTER deploy by `forge create` output (the KvWorld address):
WORLD=0x...
